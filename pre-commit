#!/usr/bin/env bash
set -euo pipefail

# Format all staged Go files and re-stage them.
go_files=$(git diff --name-only --cached --diff-filter=ACM | grep '\.go$' || true)
if [ -n "$go_files" ]; then
    gofmt -w $go_files
    git add $go_files
fi

VERSION_FILE="$(git rev-parse --show-toplevel)/VERSION"

current=$(cat "$VERSION_FILE")
IFS='.' read -r major minor patch <<< "$current"
patch=$((patch + 1))
new="${major}.${minor}.${patch}"

printf '%s' "$new" > "$VERSION_FILE"
git add "$VERSION_FILE"

echo "sdk: ${current} → ${new}"
